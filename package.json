{
  "name": "1click-temp-mail-autofill-form",
  "version": "3.0.0-beta-11",
  "description": "Generate temporary email addresses and auto-fill OTPs and login forms with one click.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "dev:safari": "wxt --browser safari",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:safari": "wxt build --browser safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:safari": "wxt zip --browser safari",
    "prepare": "wxt prepare && lefthook install",
    "clean": "wxt clean",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "format": "bun x biome format --write",
    "check": "bun x biome check",
    "bump-version": "bun scripts/bump-version.ts",
    "test": "bun test tests/unit",
    "test:watch": "bun test --watch tests/unit",
    "test:coverage": "bun test --coverage tests/unit",
    "test:e2e": "bun x playwright test",
    "test:e2e:ui": "bun x playwright test --ui",
    "test:e2e:headed": "bun x playwright test --headed",
    "check-translations": "bun scripts/check-translations.ts",
    "check-i18n-fit": "bun scripts/i18n-fit-scanner.ts"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "dompurify": "^3.4.12",
    "fflate": "^0.8.3",
    "qrcode": "^1.5.4",
    "svelte": "^5.56.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.3",
    "@types/chrome": "^0.2.2",
    "@types/qrcode": "^1.5.6",
    "@wxt-dev/module-svelte": "^2.0.5",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.10",
    "jsdom": "^29.1.1",
    "jsonc-parser": "^3.3.1",
    "rimraf": "^6.1.3",
    "svelte-check": "^4.7.3",
    "svelte-i18n": "^4.0.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "wxt": "^0.20.27"
  },
  "keywords": [
    "chrome-extension",
    "firefox-addon",
    "temp-mail",
    "autofill",
    "otp",
    "email"
  ],
  "author": "UnarchiveTech",
  "license": "MIT"
}
